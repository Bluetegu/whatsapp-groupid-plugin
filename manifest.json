{
    "manifest_version": 3,
    "name": "WhatsApp Group ID Extractor",
    "version": "1.0.0",
    "description": "Adds WhatsApp group ID information to the group info panel for easy copying to Openclaw configuration.",
    "permissions": [
        "activeTab"
    ],
    "host_permissions": [
        "*://web.whatsapp.com/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "*://web.whatsapp.com/*"
            ],
            "js": [
                "content-script.js"
            ],
            "css": [
                "styles.css"
            ],
            "run_at": "document_idle"
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "WhatsApp Group ID Extractor"
    }
}